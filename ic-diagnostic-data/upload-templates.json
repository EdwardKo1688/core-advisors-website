{
  "_meta": {
    "version": "1.0.0",
    "description": "IC 產業人才轉型診斷 — 標準上傳模板定義",
    "note": "定義各模板的必填/選填欄位、驗證規則與完備度權重"
  },

  "templates": [
    {
      "id": "TPL-COMPANY",
      "name": "公司基本資料",
      "description": "公司基本資訊與組織概況",
      "category": "basic",
      "required_fields": [
        { "field": "company_name", "label": "公司名稱", "type": "text", "validation": "non_empty" },
        { "field": "industry", "label": "產業類別", "type": "enum", "validation": "in_list", "options": ["半導體代理", "電子零組件經銷", "IC 設計", "系統整合", "OEM/ODM", "其他"] },
        { "field": "employee_count", "label": "員工人數", "type": "number", "validation": "positive_integer" },
        { "field": "annual_revenue", "label": "年營收（百萬TWD）", "type": "number", "validation": "positive_number" }
      ],
      "optional_fields": [
        { "field": "founded_year", "label": "成立年份", "type": "number", "validation": "year_range" },
        { "field": "region", "label": "主要營運區域", "type": "text" },
        { "field": "product_line_count", "label": "代理產品線數", "type": "number", "validation": "positive_integer" },
        { "field": "vendor_count", "label": "合作原廠數", "type": "number", "validation": "positive_integer" }
      ],
      "completeness_weight": 0.05
    },
    {
      "id": "TPL-ROLES",
      "name": "角色/人員清單",
      "description": "Sales、PM、FAE 人員基本資料",
      "category": "basic",
      "required_fields": [
        { "field": "name", "label": "姓名", "type": "text", "validation": "non_empty" },
        { "field": "role", "label": "角色", "type": "enum", "validation": "in_list", "options": ["Sales", "PM", "FAE", "Manager"] },
        { "field": "department", "label": "部門", "type": "text", "validation": "non_empty" }
      ],
      "optional_fields": [
        { "field": "title", "label": "職稱", "type": "text" },
        { "field": "seniority_years", "label": "年資（年）", "type": "number", "validation": "positive_number" },
        { "field": "responsible_accounts", "label": "負責客戶數", "type": "number", "validation": "positive_integer" },
        { "field": "responsible_lines", "label": "負責產品線", "type": "text" }
      ],
      "completeness_weight": 0.05
    },
    {
      "id": "TPL-CUSTOMERS",
      "name": "客戶資料",
      "description": "主要客戶清單與基本資訊",
      "category": "basic",
      "required_fields": [
        { "field": "customer_name", "label": "客戶名稱", "type": "text", "validation": "non_empty" },
        { "field": "customer_type", "label": "客戶類型", "type": "enum", "validation": "in_list", "options": ["OEM", "ODM", "EMS", "End User", "Distributor", "Other"] }
      ],
      "optional_fields": [
        { "field": "annual_revenue_from", "label": "年營收貢獻（百萬TWD）", "type": "number", "validation": "positive_number" },
        { "field": "gp_rate", "label": "毛利率（%）", "type": "number", "validation": "percentage" },
        { "field": "account_owner", "label": "負責 Sales", "type": "text" },
        { "field": "region", "label": "區域", "type": "text" },
        { "field": "status", "label": "客戶狀態", "type": "enum", "validation": "in_list", "options": ["Active", "Developing", "Dormant", "Lost"] }
      ],
      "completeness_weight": 0.10
    },
    {
      "id": "TPL-PRODUCT-LINES",
      "name": "產品線資料",
      "description": "代理產品線與原廠資訊",
      "category": "basic",
      "required_fields": [
        { "field": "line_name", "label": "產品線名稱", "type": "text", "validation": "non_empty" },
        { "field": "vendor_name", "label": "原廠名稱", "type": "text", "validation": "non_empty" }
      ],
      "optional_fields": [
        { "field": "line_revenue", "label": "產品線年營收（百萬TWD）", "type": "number", "validation": "positive_number" },
        { "field": "line_gp_rate", "label": "產品線毛利率（%）", "type": "number", "validation": "percentage" },
        { "field": "pm_owner", "label": "負責 PM", "type": "text" },
        { "field": "category", "label": "產品類別", "type": "text" },
        { "field": "vendor_tier", "label": "原廠等級", "type": "enum", "validation": "in_list", "options": ["Tier 1", "Tier 2", "Tier 3", "New"] }
      ],
