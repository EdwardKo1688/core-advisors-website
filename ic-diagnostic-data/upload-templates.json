        { "field": "period", "label": "期間（YYYY-MM 或 YYYY-Q#）", "type": "text", "validation": "period_format" },
        { "field": "revenue", "label": "營收（百萬TWD）", "type": "number", "validation": "positive_number" }
      ],
      "optional_fields": [
        { "field": "customer_name", "label": "客戶名稱", "type": "text" },
        { "field": "product_line", "label": "產品線", "type": "text" },
        { "field": "sales_owner", "label": "負責 Sales", "type": "text" },
        { "field": "target", "label": "目標營收（百萬TWD）", "type": "number", "validation": "positive_number" },
        { "field": "yoy_growth", "label": "YoY 成長率（%）", "type": "number" }
      ],
      "completeness_weight": 0.15
    },
    {
      "id": "TPL-GROSSPROFIT",
      "name": "毛利資料",
      "description": "月度或季度毛利明細",
      "category": "financial",
      "required_fields": [
        { "field": "period", "label": "期間", "type": "text", "validation": "period_format" },
        { "field": "gross_profit", "label": "毛利額（百萬TWD）", "type": "number", "validation": "positive_number" }
      ],
      "optional_fields": [
        { "field": "gp_rate", "label": "毛利率（%）", "type": "number", "validation": "percentage" },
        { "field": "customer_name", "label": "客戶名稱", "type": "text" },
        { "field": "product_line", "label": "產品線", "type": "text" },
        { "field": "target_gp_rate", "label": "目標毛利率（%）", "type": "number", "validation": "percentage" }
      ],
      "completeness_weight": 0.15
    },
    {
      "id": "TPL-EXPENSE",
      "name": "費用資料",
      "description": "經營費用與投入明細",
      "category": "financial",
      "required_fields": [
        { "field": "period", "label": "期間", "type": "text", "validation": "period_format" },
        { "field": "expense_type", "label": "費用類型", "type": "enum", "validation": "in_list", "options": ["交通差旅", "招待", "樣品", "行銷推廣", "教育訓練", "其他"] },
        { "field": "amount", "label": "金額（TWD）", "type": "number", "validation": "positive_number" }
      ],
      "optional_fields": [
        { "field": "customer_name", "label": "對應客戶", "type": "text" },
        { "field": "owner", "label": "負責人", "type": "text" },
        { "field": "purpose", "label": "用途說明", "type": "text" }
      ],
      "completeness_weight": 0.10
    },
    {
      "id": "TPL-PROJECTS",
      "name": "專案資料",
      "description": "Design-in / Design-win 專案追蹤",
      "category": "operational",
      "required_fields": [
        { "field": "project_name", "label": "專案名稱", "type": "text", "validation": "non_empty" },
        { "field": "customer_name", "label": "客戶名稱", "type": "text", "validation": "non_empty" },
        { "field": "stage", "label": "階段", "type": "enum", "validation": "in_list", "options": ["Evaluation", "Design-in", "Design-win", "Mass Production", "EOL", "Lost"] }
      ],
      "optional_fields": [
        { "field": "product_line", "label": "產品線", "type": "text" },
        { "field": "fae_owner", "label": "負責 FAE", "type": "text" },
        { "field": "sales_owner", "label": "負責 Sales", "type": "text" },
        { "field": "estimated_revenue", "label": "預估年營收（百萬TWD）", "type": "number", "validation": "positive_number" },
        { "field": "start_date", "label": "起始日期", "type": "text", "validation": "date_format" },
        { "field": "expected_mp_date", "label": "預計量產日期", "type": "text", "validation": "date_format" }
      ],
      "completeness_weight": 0.15
    },
    {
      "id": "TPL-FORECAST",
      "name": "Forecast / Funnel 資料",
      "description": "銷售預測與商機管道",
      "category": "operational",
      "required_fields": [
        { "field": "period", "label": "預測期間", "type": "text", "validation": "period_format" },
        { "field": "forecast_revenue", "label": "預測營收（百萬TWD）", "type": "number", "validation": "positive_number" }
      ],
      "optional_fields": [
        { "field": "actual_revenue", "label": "實際營收（百萬TWD）", "type": "number", "validation": "positive_number" },
        { "field": "accuracy_rate", "label": "預測準確率（%）", "type": "number", "validation": "percentage" },
        { "field": "product_line", "label": "產品線", "type": "text" },
        { "field": "pipeline_value", "label": "管道總金額（百萬TWD）", "type": "number", "validation": "positive_number" },
        { "field": "pipeline_count", "label": "管道案件數", "type": "number", "validation": "positive_integer" }
      ],
      "completeness_weight": 0.10
    },
    {
      "id": "TPL-SUPPORT",
      "name": "支援活動資料",
      "description": "FAE 技術支援與客戶拜訪紀錄",
      "category": "operational",
      "required_fields": [
        { "field": "date", "label": "日期", "type": "text", "validation": "date_format" },
        { "field": "activity_type", "label": "活動類型", "type": "enum", "validation": "in_list", "options": ["技術支援", "客戶拜訪", "問題排除", "Design-in 支援", "教育訓練", "其他"] },
        { "field": "customer_name", "label": "客戶名稱", "type": "text", "validation": "non_empty" }
      ],
      "optional_fields": [
        { "field": "owner", "label": "負責人", "type": "text" },
        { "field": "duration_hours", "label": "時數", "type": "number", "validation": "positive_number" },
        { "field": "outcome", "label": "成果", "type": "enum", "validation": "in_list", "options": ["已解決", "進行中", "需原廠支援", "無結論"] },
        { "field": "notes", "label": "備註", "type": "text" }
      ],
      "completeness_weight": 0.05
    }
  ],

  "validationRules": {
    "non_empty": { "description": "不得為空", "regex": ".+" },
    "positive_number": { "description": "正數", "check": "value > 0" },
    "positive_integer": { "description": "正整數", "check": "Number.isInteger(value) && value > 0" },
    "percentage": { "description": "0-100 之間的數字", "check": "value >= 0 && value <= 100" },
    "year_range": { "description": "合理年份", "check": "value >= 1950 && value <= 2030" },
    "period_format": { "description": "YYYY-MM 或 YYYY-Q#", "regex": "^\\d{4}-(0[1-9]|1[0-2]|Q[1-4])$" },
    "date_format": { "description": "YYYY-MM-DD", "regex": "^\\d{4}-\\d{2}-\\d{2}$" },
    "in_list": { "description": "必須為選項之一", "check": "options.includes(value)" }
  },

  "completenessThresholds": {
    "basic": { "min": 0, "max": 0.29, "label": "基礎", "description": "僅問卷資料" },
    "advanced": { "min": 0.30, "max": 0.69, "label": "進階", "description": "問卷 + 部分上傳資料" },
    "comprehensive": { "min": 0.70, "max": 1.0, "label": "完整", "description": "問卷 + 完整上傳資料" }
  },

  "fieldMappingAliases": {
    "company_name": ["公司名稱", "公司", "Company", "Company Name", "company"],
    "customer_name": ["客戶名稱", "客戶", "Customer", "Customer Name", "customer"],
    "revenue": ["營收", "Revenue", "Sales Amount", "銷售額"],
    "gross_profit": ["毛利", "毛利額", "Gross Profit", "GP"],
    "gp_rate": ["毛利率", "GP Rate", "GP%", "Margin"],
    "period": ["期間", "Period", "月份", "Month", "Quarter"],
    "name": ["姓名", "Name", "員工姓名"],
    "role": ["角色", "Role", "職務"],
    "department": ["部門", "Department", "Dept"],
    "product_line": ["產品線", "Product Line", "Line"],
    "vendor_name": ["原廠", "Vendor", "原廠名稱"],
    "project_name": ["專案名稱", "Project", "Project Name"],
    "stage": ["階段", "Stage", "Status"],
    "amount": ["金額", "Amount"]
  },

  "uploadFailureMessages": {
    "invalid_format": "檔案格式不支援，請上傳 .xlsx 或 .csv 格式。",
    "empty_file": "檔案內容為空，請確認檔案是否正確。",
    "missing_required": "缺少必填欄位：{fields}。請補充後重新上傳，或選擇退回問卷模式。",
    "invalid_value": "欄位「{field}」第 {row} 列資料格式錯誤：{reason}。",
    "mapping_failed": "以下欄位無法自動映射：{fields}。請手動指定對應欄位。",
    "parse_error": "檔案解析失敗：{reason}。請確認檔案未損壞。"
  }
}
