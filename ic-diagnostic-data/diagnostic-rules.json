{
  "_meta": {
    "version": "1.0.0",
    "description": "IC 產業人才轉型診斷 — 完整診斷規則引擎",
    "note": "所有閾值為暫定值，可由後台管理介面調整。規則按 severity × priority 排序。"
  },

  "rules": [
    {
      "id": "RULE-01",
      "name": "高營收低毛利",
      "category": "profitability",
      "roleScope": ["sales", "pm"],
      "condition": {
        "type": "and",
        "checks": [
          { "model": "revenue", "category": "result", "operator": ">=", "threshold": 3.5 },
          { "model": "grossprofit", "category": "result", "operator": "<=", "threshold": 2.5 }
        ]
      },
      "severity": "high",
      "priority": 1,
      "flag": "營收健康但毛利侵蝕",
      "insight": "營收達成良好但毛利率偏低，顯示可能存在價格讓步過多、低毛利客戶佔比過高、或缺乏有效的定價管理機制。",
      "actions": [
        { "text": "盤點前 10 大客戶毛利率，辨識低毛利來源", "timeframe": "2 週內", "priority": "P1" },
        { "text": "檢視折扣審核流程，建立毛利底線機制", "timeframe": "1 個月內", "priority": "P1" },
        { "text": "與 PM 對齊產品定價策略，識別可提價空間", "timeframe": "1 個月內", "priority": "P2" }
      ]
    },
    {
      "id": "RULE-02",
      "name": "高支援低轉換",
      "category": "efficiency",
      "roleScope": ["fae"],
      "condition": {
        "type": "and",
        "checks": [
          { "model": "expense", "category": "result", "operator": "<=", "threshold": 2.5 },
          { "model": "contribution", "category": "result", "operator": "<=", "threshold": 2.5 }
        ]
      },
      "severity": "high",
      "priority": 2,
      "flag": "技術支援投入產出失衡",
      "insight": "FAE 技術支援投入大但 design-win 轉換率低，顯示支援資源可能分散在低價值客戶，或支援流程缺乏案件分級機制。",
      "actions": [
        { "text": "建立支援案件分級制度（A/B/C 級客戶）", "timeframe": "2 週內", "priority": "P1" },
        { "text": "檢視低轉換專案，辨識技術瓶頸或商務障礙", "timeframe": "1 個月內", "priority": "P1" },
        { "text": "與 Sales 對齊客戶優先順序，聚焦高價值案件", "timeframe": "2 週內", "priority": "P2" }
      ]
    },
    {
      "id": "RULE-03",
      "name": "預測品質偏弱",
      "category": "planning",
      "roleScope": ["pm"],
      "condition": {
        "type": "and",
        "checks": [
          { "model": "expense", "category": "quality", "operator": "<=", "threshold": 2.5 }
        ]
      },
      "severity": "high",
      "priority": 3,
      "flag": "Forecast 準確率不足",
      "insight": "Forecast 預測準確率偏低，可能導致庫存過高、缺貨風險、或資源錯配。PM 與 Sales 的需求對齊機制可能不足。",
      "actions": [
        { "text": "建立月度 forecast review 機制，與 Sales 定期對齊", "timeframe": "2 週內", "priority": "P1" },
        { "text": "追蹤 forecast accuracy 趨勢，設定改善目標", "timeframe": "1 個月內", "priority": "P2" },
        { "text": "檢視庫存週轉率，辨識呆滯料風險", "timeframe": "1 個月內", "priority": "P2" }
      ]
    },
    {
      "id": "RULE-04",
      "name": "費用投入未形成成果",
      "category": "efficiency",
      "roleScope": ["sales", "pm"],
      "condition": {
        "type": "and",
        "checks": [
          { "model": "expense", "category": "result", "operator": "<=", "threshold": 2.0 },
          { "model": "contribution", "category": "result", "operator": "<=", "threshold": 2.5 }
        ]
      },
      "severity": "high",
      "priority": 4,
      "flag": "經營投入效率低落",
      "insight": "經營費用（交通、招待、樣品等）投入偏高，但新客戶開發或商機轉化未見同步成長，投入產出比偏低。",
      "actions": [
        { "text": "盤點費用結構，辨識低效投入來源", "timeframe": "2 週內", "priority": "P1" },
        { "text": "建立費用與成果對應追蹤機制", "timeframe": "1 個月內", "priority": "P1" },
        { "text": "設定費用預算上限與審核機制", "timeframe": "1 個月內", "priority": "P2" }
      ]
    },
    {
      "id": "RULE-05",
      "name": "跨部門協同不足",
      "category": "collaboration",
      "roleScope": ["sales", "pm", "fae"],
      "condition": {
        "type": "and",
        "checks": [
          { "model": "capability", "category": "synergy", "operator": "<=", "threshold": 2.0 }
        ]
      },
      "severity": "medium",
      "priority": 5,
      "flag": "三方協同斷裂",
      "insight": "Sales / PM / FAE 之間資訊不同步、各做各的，客戶服務品質與商機轉化效率受影響。",
      "actions": [
        { "text": "建立重點客戶聯合服務團隊（Sales + PM + FAE）", "timeframe": "2 週內", "priority": "P1" },
        { "text": "建立定期三方同步機制（週會或雙週會）", "timeframe": "2 週內", "priority": "P2" },
        { "text": "導入共享客戶資訊看板或 CRM", "timeframe": "3 個月內", "priority": "P3" }
      ]
    },
    {
      "id": "RULE-06",
      "name": "角色能力缺口",
      "category": "capability",
      "roleScope": ["sales", "pm", "fae"],
      "condition": {
        "type": "and",
        "checks": [
          { "model": "capability", "category": "result", "operator": "<=", "threshold": 2.0 }
        ]
      },
      "severity": "medium",
      "priority": 6,
      "flag": "核心職能待強化",
      "insight": "角色核心能力存在明顯缺口，可能影響客戶信任度、技術支援品質或商務談判能力。",
      "actions": [
        { "text": "規劃角色別培訓計畫（技術 / 方法論 / 產品知識）", "timeframe": "1 個月內", "priority": "P1" },
        { "text": "建立 mentor / buddy 機制，加速能力養成", "timeframe": "1 個月內", "priority": "P2" },
        { "text": "導入實戰演練（客戶模擬、QBR 練習）", "timeframe": "2 個月內", "priority": "P2" }
      ]
    },
    {
      "id": "RULE-07",
      "name": "商機管道不足",
      "category": "growth",
      "roleScope": ["sales"],
      "condition": {
        "type": "and",
        "checks": [
          { "model": "contribution", "category": "quality", "operator": "<=", "threshold": 2.0 }
        ]
      },
      "severity": "high",
      "priority": 7,
      "flag": "管道枯竭風險",
      "insight": "商機管道（pipeline / funnel）不足或階段不均衡，過度依賴少數大案，營收可持續性風險高。",
      "actions": [
        { "text": "盤點現有管道各階段案件數與金額分佈", "timeframe": "1 週內", "priority": "P1" },
        { "text": "設定每月新增商機目標，建立開發節奏", "timeframe": "2 週內", "priority": "P1" },
        { "text": "擴大客戶開發來源（展會、原廠轉介、產業社群）", "timeframe": "2 個月內", "priority": "P2" }
      ]
    },
    {
      "id": "RULE-08",
      "name": "原廠關係薄弱",
      "category": "partnership",
      "roleScope": ["pm"],
      "condition": {
        "type": "and",
        "checks": [
          { "model": "contribution", "category": "quality", "operator": "<=", "threshold": 2.0 }
        ]
      },
      "severity": "medium",
      "priority": 8,
      "flag": "原廠夥伴關係不足",
      "insight": "與原廠互動深度不足，可能影響價格保護、資源取得、roadmap 掌握與聯合推廣機會。",
      "actions": [
        { "text": "主動規劃與重點原廠的 QBR 會議", "timeframe": "2 週內", "priority": "P1" },
        { "text": "提出聯合行銷或技術研討會計畫", "timeframe": "1 個月內", "priority": "P2" },
        { "text": "爭取 roadmap sharing 與優先資源配置", "timeframe": "2 個月內", "priority": "P2" }
      ]
    },
    {
      "id": "RULE-09",
      "name": "客戶集中度過高",
      "category": "risk",
      "roleScope": ["sales"],
      "condition": {
        "type": "and",
        "checks": [
          { "model": "revenue", "category": "quality", "operator": "<=", "threshold": 2.0 }
        ]
      },
      "severity": "high",
      "priority": 9,
      "flag": "營收來源過度集中",
      "insight": "前三大客戶佔比過高，一旦主力客戶流失或縮減採購，將嚴重衝擊營收。",
      "actions": [
        { "text": "辨識並啟動 3-5 個潛力客戶的深化經營計畫", "timeframe": "1 個月內", "priority": "P1" },
        { "text": "對主力客戶建立多產品線滲透策略", "timeframe": "1 個月內", "priority": "P2" },
        { "text": "評估是否有產業或區域分散機會", "timeframe": "2 個月內", "priority": "P3" }
      ]
    },
    {
      "id": "RULE-10",
      "name": "客戶深耕不足",
      "category": "growth",
      "roleScope": ["sales"],
      "condition": {
        "type": "and",
        "checks": [
          { "model": "contribution", "category": "trend", "operator": "<=", "threshold": 2.0 }
        ]
      },
      "severity": "medium",
      "priority": 10,
      "flag": "客戶滲透率下降",
      "insight": "單一客戶覆蓋的產品線數呈萎縮趨勢，可能失去 cross-selling 機會或被競爭者侵入。",
      "actions": [
        { "text": "針對前 10 大客戶做 wallet share 分析", "timeframe": "2 週內", "priority": "P1" },
        { "text": "與 PM/FAE 聯合拜訪，推動跨產品線方案", "timeframe": "1 個月內", "priority": "P2" }
      ]
    },
    {
      "id": "RULE-11",
      "name": "Design-in 轉化瓶頸",
      "category": "conversion",
      "roleScope": ["fae", "pm"],
      "condition": {
        "type": "and",
        "checks": [
          { "model": "contribution", "category": "synergy", "operator": "<=", "threshold": 2.5 }
        ]
      },
      "severity": "medium",
      "priority": 11,
      "flag": "Design-in 轉換率偏低",
      "insight": "Design-in 到 design-win 的轉換率偏低，可能是技術支援品質、商務跟進或競品因素。",
      "actions": [
        { "text": "分析近半年 lost 案件的根因（技術/商務/競品）", "timeframe": "2 週內", "priority": "P1" },
        { "text": "建立 design-in review 機制，及早辨識風險案件", "timeframe": "1 個月內", "priority": "P2" }
      ]
    },
    {
      "id": "RULE-12",
      "name": "營收趨勢惡化",
      "category": "growth",
      "roleScope": ["sales", "pm"],
      "condition": {
        "type": "and",
        "checks": [
          { "model": "revenue", "category": "trend", "operator": "<=", "threshold": 2.0 }
        ]
      },
      "severity": "high",
      "priority": 12,
      "flag": "營收成長動能不足",
      "insight": "近期營收呈衰退趨勢，需盡快辨識衰退原因並採取行動。",
      "actions": [
        { "text": "分析衰退來源：客戶流失、訂單減少或價格下滑", "timeframe": "1 週內", "priority": "P1" },
        { "text": "對衰退前 5 大客戶進行緊急拜訪與挽回計畫", "timeframe": "2 週內", "priority": "P1" },
        { "text": "加速新客戶與新專案開發節奏", "timeframe": "1 個月內", "priority": "P2" }
      ]
    }
  ],

  "riskSortLogic": {
    "description": "風險排序規則：先按 severity（high > medium > low），再按 priority 數字（小優先）",
    "topN": 3
  },

  "actionSortLogic": {
    "description": "行動建議排序：從所有觸發規則的 actions 中，按 priority（P1 > P2 > P3）排序，取前 3-5 條",
    "topN": 5
  },

  "conservativeMode": {
    "description": "資料不足時的保守判讀規則",
    "rules": [
      { "condition": "模型內題目回答數 < 2", "action": "該模型分數標記為「參考值」，不納入紅旗判定" },
      { "condition": "整體回答完成率 < 60%", "action": "結果頁顯示「診斷資料不足」警示，建議補充回答" },
      { "condition": "上傳資料缺失某模型全部欄位", "action": "該模型僅以問卷分數計算，附註「建議補充資料提升精度」" },
      { "condition": "紅旗觸發但資料完備度 < 30%", "action": "紅旗標記為「潛在風險（待驗證）」而非「確認風險」" }
    ]
  },

  "roleActionTemplates": {
    "sales": {
      "strengthMessages": [
        "營收達成與客戶開發能力突出，建議持續深化高價值客戶經營。",
        "商機管道管理良好，具備穩健的業務發展基礎。",
        "具備結構化銷售方法論，客戶經營深度佳。"
      ],
      "improvementMessages": [
        "建議強化毛利意識，避免過度依賴價格競爭。",
        "建議擴大商機來源多元性，降低對少數客戶的依賴。",
        "建議強化與 PM / FAE 的協同機制，提升客戶服務團隊效能。"
      ]
    },
    "pm": {
      "strengthMessages": [
        "產品線經營穩健，與原廠關係良好。",
        "定價策略與毛利管理具備系統化基礎。",
        "Forecast 準確率佳，庫存管理有效。"
      ],
      "improvementMessages": [
        "建議強化 forecast 機制，提升預測準確率與庫存週轉。",
        "建議深化與原廠的策略合作關係（QBR / roadmap sharing）。",
        "建議與 Sales 更緊密對齊客戶需求變化。"
      ]
    },
    "fae": {
      "strengthMessages": [
        "技術支援深度與 design-win 轉換率表現優異。",
        "跨產品線整合能力強，能提出完整技術方案。",
        "問題解決效率高，客戶技術滿意度佳。"
      ],
      "improvementMessages": [
        "建議建立支援案件分級制度，聚焦高價值客戶。",
        "建議強化技術成果回饋機制，讓 Sales / PM 能善用技術優勢。",
        "建議提升商業敏感度，將技術支援與營收貢獻連結。"
      ]
    }
  }
}
